{
  "rewrites": [
    { "source": "/", "destination": "/api/index" },
    { "source": "/project/MyBrowser", "destination": "/project/MyBrowser/index.html" },
    { "source": "/project/MyBrowser/download", "destination": "/project/MyBrowser/download.html" },
    { "source": "/MyBrowser", "destination": "/MyBrowser/index.html" },
    { "source": "/product", "destination": "/product/music-visualizer.html" },
    { "source": "/product/focus", "destination": "/product/focus.html" },
    { "source": "/product/ClientBot", "destination": "/product/ClientBot.html" },
    { "source": "/product/clientbot", "destination": "/product/ClientBot.html" },
    { "source": "/register", "destination": "/register.html" },
    { "source": "/login", "destination": "/login.html" }
  ],
  "redirects": [
    {
      "source": "/:path((?!project|MyBrowser|product|register|login|auth\\.js|components|api|404).+)",
      "destination": "/404.html",
      "permanent": false
    }
  ]
}